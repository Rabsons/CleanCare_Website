# =============================================================================
# CleanCare Solutions — Environment Configuration Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=https://cleancare.example.com
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_64
DEBUG=false

# -----------------------------------------------------------------------------
# Database
# SQLite (development):   DATABASE_URL=sqlite+aiosqlite:///./cleancare_dev.db
# PostgreSQL (production): DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./cleancare_dev.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# -----------------------------------------------------------------------------
# Redis (Session Store)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_SSL=false

# -----------------------------------------------------------------------------
# Session Configuration
# -----------------------------------------------------------------------------
SESSION_ABSOLUTE_TIMEOUT_SECONDS=28800
SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_MAX_CONCURRENT=3
SESSION_COOKIE_NAME=session
SESSION_STRICT_IP_BINDING=false

# -----------------------------------------------------------------------------
# CSRF
# -----------------------------------------------------------------------------
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TOKEN_ROTATION_DAYS=1

# -----------------------------------------------------------------------------
# Rate Limiting (attempts / window_seconds)
# -----------------------------------------------------------------------------
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
RATE_LIMIT_REGISTER_ATTEMPTS=3
RATE_LIMIT_REGISTER_WINDOW_SECONDS=3600
RATE_LIMIT_PASSWORD_RESET_ATTEMPTS=3
RATE_LIMIT_PASSWORD_RESET_WINDOW_SECONDS=3600
RATE_LIMIT_UPLOAD_ATTEMPTS=10
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=3600

# -----------------------------------------------------------------------------
# Account Lockout
# -----------------------------------------------------------------------------
LOCKOUT_FAILURE_THRESHOLD=10
LOCKOUT_CAPTCHA_THRESHOLD=5
LOCKOUT_DURATION_SECONDS=900
LOCKOUT_ALERT_THRESHOLD=20

# -----------------------------------------------------------------------------
# Password Policy
# -----------------------------------------------------------------------------
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SYMBOL=true
PASSWORD_HIBP_CHECK=true

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@cleancare.example.com
MAIL_PASSWORD=CHANGE_ME_smtp_password
MAIL_USE_TLS=true
MAIL_FROM=noreply@cleancare.example.com
MAIL_FROM_NAME=CleanCare Solutions

# -----------------------------------------------------------------------------
# Email Verification & Password Reset
# -----------------------------------------------------------------------------
EMAIL_VERIFY_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15

# -----------------------------------------------------------------------------
# File Uploads
# -----------------------------------------------------------------------------
UPLOAD_MAX_SIZE_BYTES=5242880
UPLOAD_STORAGE_PATH=/private/uploads
UPLOAD_SIGNED_URL_EXPIRE_MINUTES=60
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://cleancare.example.com

# -----------------------------------------------------------------------------
# MFA
# -----------------------------------------------------------------------------
MFA_ISSUER_NAME=CleanCare Solutions
MFA_TOTP_WINDOW=1

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_SECURITY_EVENTS=true
